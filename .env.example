# =============================================================================
# Sqordia Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.
#
# All secrets previously in appsettings.json have been moved here.
# The appsettings.json file now contains only ${PLACEHOLDER} references.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=                          # PostgreSQL password (change from default)

# Connection string override (optional — overrides appsettings.json)
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=SqordiaDb;Username=sqordia;Password=YOUR_PASSWORD;Pooling=true;MinPoolSize=5;MaxPoolSize=50

# ── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=                           # Min 32 chars. Generate with: openssl rand -base64 48

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=               # From Google Cloud Console
GOOGLE_OAUTH_CLIENT_SECRET=           # From Google Cloud Console

# ── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=                       # From https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=                    # From https://console.anthropic.com/settings/keys
GEMINI_API_KEY=                       # From https://aistudio.google.com/apikey

# ── AI Python Service ───────────────────────────────────────────────────────
AI_SERVICE_KEY=                       # Shared secret between .NET backend and Python service
ENVIRONMENT=development               # Set to "production" in prod (enforces AI_SERVICE_KEY)

# ── Stripe Payments ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                    # From https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=               # From https://dashboard.stripe.com/apikeys (public)
STRIPE_WEBHOOK_SECRET=                # From Stripe Dashboard > Webhooks > Signing secret

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=                       # From https://resend.com/api-keys
RESEND_FROM_EMAIL=noreply@sqordia.app
RESEND_FROM_NAME=Sqordia

# ── GitHub Integration ───────────────────────────────────────────────────────
GITHUB_TOKEN=                         # Fine-grained PAT from https://github.com/settings/tokens

# ── Settings Encryption ─────────────────────────────────────────────────────
SETTINGS_ENCRYPTION_KEY=              # Base64-encoded 256-bit key. Generate with: openssl rand -base64 32

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:5173
